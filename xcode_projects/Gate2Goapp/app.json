{
  "expo": {
    "name": "Gate2Go - Fence & Gate Design",
    "slug": "gate2go",
    "version": "1.0.0",
    "description": "Professional fence and gate design tool for contractors. Create accurate quotes, design custom gates, and generate branded proposals. Features gate layout planner, fence estimator, material calculator, and pricing tools.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gate2go",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gate2go.app",
      "infoPlist": {
        "CFBundleDisplayName": "Gate2Go"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gate2go.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "Gate2Go - Fence & Gate Design Tool",
      "shortName": "Gate2Go",
      "description": "Professional fence and gate design tool for contractors. Create quotes, design gates, generate proposals.",
      "themeColor": "#2563EB",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2563EB",
          "dark": {
            "backgroundColor": "#1E293B"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
