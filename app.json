{
  "expo": {
    "name": "SafeRestore Concierge",
    "slug": "saferestore",
    "version": "1.0.0",
    "description": "Consent-based iOS data recovery concierge. Get AI-guided recovery plans, official account recovery steps, and trusted repair routing without bypassing device security.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saferestore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saferestore.app",
      "infoPlist": {
        "CFBundleDisplayName": "SafeRestore"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saferestore.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "SafeRestore Concierge",
      "shortName": "SafeRestore",
      "description": "Consent-based iOS data recovery concierge with AI guidance and trusted service routing.",
      "themeColor": "#2563EB",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2563EB",
          "dark": {
            "backgroundColor": "#1E293B"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
